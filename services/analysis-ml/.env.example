# --- analysis-ml (S8 Embedding Service) ---
PORT=8000
LOG_LEVEL=INFO

# Model / embedding behaviour
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
NORMALIZE=true
DEVICE=cpu
BACKEND=sentence-transformers
# Where model weights are cached (mount a volume here to avoid re-downloading).
MODEL_CACHE_DIR=./models

# Request shaping (embedding)
MAX_BATCH_SIZE=64
MAX_CONCURRENCY=4
WARM_UP=true

# --- NER (S9) ---
# en_core_web_sm (light) by default; en_core_web_lg / en_core_web_trf are drop-in.
SPACY_MODEL=en_core_web_sm
USE_TRANSFORMER=false
NER_MAX_BATCH_SIZE=32
NER_MAX_CONCURRENCY=4
# Optional default label filter (comma-separated); empty returns all labels.
# ENTITY_TYPES=ORG,GPE,DATE,PERSON,MONEY
# CUSTOM_RULER_URL=
