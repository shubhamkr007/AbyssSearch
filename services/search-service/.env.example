# --- S3 Search Service ---
PORT=8080

# Elasticsearch (matches infra/docker-compose.yml; security disabled in dev)
ELASTICSEARCH_URL=http://localhost:9200
# In production set a least-privilege API key (read on the tenant index pattern):
ELASTICSEARCH_API_KEY=

# Embedding Service (S8 / analysis-ml) for query vectors
EMBEDDING_SERVICE_URL=http://localhost:8000
EMBEDDING_TIMEOUT_MS=1500

# Optional Valkey (query/vector cache); empty is fine (in-process LRU still used)
REDIS_URL=

# Hybrid retrieval
HYBRID_MODE=client_rrf          # client_rrf (free tier default) | native_rrf (licensed clusters)
RRF_RANK_CONSTANT=60
RRF_RANK_WINDOW=100
KNN_K=50
KNN_NUM_CANDIDATES=200

# Paging / behavior
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=50
DID_YOU_MEAN_THRESHOLD=3
ES_TIMEOUT_MS=3000
VECTOR_CACHE_SIZE=500
QUERY_CACHE_TTL=60

LOG_LEVEL=info

# Dev/test: use the in-memory fake backend + fake embedder (no Elasticsearch needed)
USE_FAKE=false
