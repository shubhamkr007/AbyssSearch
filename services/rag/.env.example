# RAG Service (S12)
PORT=8092
LOG_LEVEL=info

# Retrieval (same ES the ingestion pipeline writes to)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_API_KEY=
EMBEDDING_SERVICE_URL=http://localhost:8000

# Generation (self-hosted, zero-cost). If Ollama is not running the service
# degrades to an extractive answer from the top source.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

TOP_K=5
RANK_WINDOW=20
KNN_K=20
KNN_NUM_CANDIDATES=100
RRF_RANK_CONSTANT=60
PER_PASSAGE_CHARS=1200
MAX_CONTEXT_CHARS=6000

EMBED_TIMEOUT_MS=5000
ES_TIMEOUT_MS=5000
LLM_TIMEOUT_MS=60000

# USE_FAKE=true -> fake retriever + fake LLM (no ES/Ollama needed), for tests/offline.
USE_FAKE=false
