# --- S4 Tenant/Config Service ---
PORT=8000

# PostgreSQL (matches infra/docker-compose.yml)
# Prefer 127.0.0.1 over localhost on Windows (avoids ::1 vs Docker IPv4 publish).
DATABASE_URL=postgresql://tenant_config:tenant_config@127.0.0.1:5432/tenant_config?schema=public

# Valkey (leave empty to disable pub/sub invalidation; the service degrades gracefully)
REDIS_URL=redis://localhost:6379
CONFIG_EVENT_CHANNEL=config:invalidate

# Admin auth (Phase 1 placeholder shared secret; Phase 3 -> OIDC/JWT + RBAC).
# REQUIRED: admin write routes reject all requests when this is empty.
ADMIN_TOKEN=dev-admin-token

# API key hashing
API_KEY_HASH_ALGO=argon2id

LOG_LEVEL=info

# Dev/demo only: run without Postgres using the in-memory repository (not persisted).
USE_IN_MEMORY=false
