# --- S2 API Gateway / BFF ---
PORT=3000

# Downstream services (match local ports of S4 and S3)
CONFIG_SERVICE_URL=http://localhost:8000
SEARCH_SERVICE_URL=http://localhost:8080
RAG_SERVICE_URL=

# Optional Valkey (future: distributed rate limiting + config cache)
REDIS_URL=

# Rate limiting / caching / resilience
RATE_LIMIT_DEFAULT=60          # requests per minute when a key has no explicit limit
CORS_STRICT=false
CONFIG_CACHE_TTL_SECONDS=30
KEY_CACHE_TTL_SECONDS=30
DOWNSTREAM_TIMEOUT_MS=3000

RAG_ENABLED=false
LOG_LEVEL=info

# Dev/test: seeded in-memory fakes for Config + Search (no downstreams needed).
# In this mode use the demo key:  Authorization: Bearer pk_test_demo
USE_FAKE=false
