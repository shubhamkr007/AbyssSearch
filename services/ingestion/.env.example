# --- S5/S6 Ingestion Orchestrator + Workers ---
PORT=8090
ADMIN_TOKEN=dev-admin-token
LOG_LEVEL=info

# Job metadata (Postgres in prod; SQLite ok for local/dev)
DATABASE_URL=sqlite+pysqlite:///./ingestion.db

# Celery / Valkey (used when USE_INLINE=false)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Downstream
CONFIG_SERVICE_URL=http://localhost:8001
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_API_KEY=
EMBEDDING_SERVICE_URL=http://localhost:8000
NER_SERVICE_URL=http://localhost:8000
DOWNSTREAM_TIMEOUT_MS=5000

# Pipeline
MAX_BULK_BATCH=100
DEFAULT_CHUNK_SIZE=800
DEFAULT_CHUNK_OVERLAP=100
BULK_BATCH_SIZE=50
MAX_RETRIES=3

# Dev/test: in-memory job store + fake ES/embed/NER; run pipeline in-process (no Celery)
USE_FAKE=true
USE_INLINE=true
