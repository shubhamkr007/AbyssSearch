# S13 Analytics Service - copy to .env and adjust as needed.
PORT=8093
LOG_LEVEL=info

# Shared admin token: the gateway forwards it on /events; the Admin Console
# sends it when reading reports.
ADMIN_TOKEN=dev-admin-token
CORS_ORIGINS=*

# Storage. Analytics indices are named `analytics-{tenant}` (e.g. analytics-demo)
# so they never collide with the content indices the search service reads via
# the `{tenant}-*` wildcard.
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_API_KEY=
ANALYTICS_INDEX_PREFIX=analytics
ES_TIMEOUT_MS=5000

# Buffering (best-effort, never blocks search).
BUFFER_SIZE=200
FLUSH_INTERVAL_MS=2000
REFRESH_ON_FLUSH=true
SAMPLING_RATE=1.0
DEFAULT_REPORT_DAYS=7

# USE_FAKE=true uses an in-memory store (no Elasticsearch needed).
USE_FAKE=false
