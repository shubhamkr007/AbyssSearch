{
  "name": "@enterprise-search/widget",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "S1 - embeddable enterprise-search Web Component (React 18 + Vite + r2wc). Talks only to the API Gateway /v1/*.",
  "license": "Apache-2.0",
  "files": ["dist"],
  "main": "./dist/enterprise-search.js",
  "module": "./dist/enterprise-search.js",
  "exports": {
    ".": "./dist/enterprise-search.js"
  },
  "sideEffects": ["./dist/enterprise-search.js"],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@r2wc/react-to-web-component": "^2.0.3",
    "@tanstack/react-query": "^5.51.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^24.1.1",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  }
}
